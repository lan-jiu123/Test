# ============================================================
# 设备检修AI系统 - 环境配置
# 适配：银河麒麟高级服务器版 V10/V11 + LoongArch架构
# ============================================================

# --- 运行环境 ---
ENVIRONMENT=production
APP_DEBUG=false

# --- API服务 ---
API_HOST=0.0.0.0
API_PORT=8000

# --- 数据存储 ---
# 留空时默认使用项目根目录 data/
# DATA_DIR=/absolute/path/to/data
# DATABASE_PATH=/absolute/path/to/equipment_maintenance.db
# DOCUMENT_UPLOAD_DIR=/absolute/path/to/uploads/documents
MAX_DOCUMENT_UPLOAD_MB=100

# --- 知识检索向量 ---
# local_hash：纯 Python 离线兜底，适合 LoongArch 初期验证
# api：调用 OpenAI 兼容的 /embeddings 接口
EMBEDDING_BACKEND=local_hash
LOCAL_EMBEDDING_DIMENSION=384
EMBEDDING_MODEL=local-char-ngram-v1
EMBEDDING_API_URL=
EMBEDDING_API_KEY=

# --- 安全配置 ---
SECRET_KEY=change-this-to-a-secure-random-string
ACCESS_TOKEN_EXPIRE_HOURS=2

# --- CORS ---
CORS_ORIGINS=["http://localhost:8000","http://localhost:3000"]

# --- 大模型配置 ---
# 可选: longcat (云端) / ollama (本地离线)
LLM_BACKEND=longcat
LLM_TEMPERATURE=0.3

# LongCat 云端配置
LONGCAT_API_KEY=
LONGCAT_API_URL=https://api.longcat.chat/openai
LONGCAT_MODEL=LongCat-2.0

# Ollama 本地配置（离线模式）
OLLAMA_API_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
